# AXIOM ⚡ Structured Inefficiency Engine v4.0
# All core data sources are free and require no API keys:
#   ESPN Soccer API  : https://site.api.espn.com/apis/site/v2/sports/soccer
#   TheSportsDB      : https://www.thesportsdb.com/api/v1/json/3 (free tier, key=3)
#
# Optional API keys unlock additional features:
#
# Anthropic — enables AI-assisted analysis (optional)
# ANTHROPIC_API_KEY=your_key_here
#
# Pinnacle — enables true CLV computation (optional; currently uses proxy CLV)
# PINNACLE_API_KEY=your_key_here
#
# The Odds API — enables live market odds and real edge computation (optional)
# THE_ODDS_API_KEY=your_key_here
#
# Betfair — enables exchange liquidity data (optional)
# BETFAIR_API_KEY=your_key_here
#
# Football-Data.org — enables squad/lineup/injury data (optional)
# FOOTBALL_DATA_API_KEY=your_key_here
#
# Auto-refresh interval in milliseconds (default: 60000 = 60s)
# AXIOM_REFRESH_INTERVAL=60000
